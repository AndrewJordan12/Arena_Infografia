shader_type canvas_item;

// === HIT FLASH (âœ… reusado del mĂ³dulo 10) =================================
// EL PUENTE juegoâ†’shader: GDScript escribe el uniform con
// set_shader_parameter(). Al recibir daĂ±o, el script sube intensidad_flash a
// 1.0 y un tween la baja a 0.0. El shader mezcla el color hacia BLANCO segĂºn
// esa intensidad â€” el clĂ¡sico "recibĂ­ daĂ±o" de todos los juegos.
// ==========================================================================

uniform float intensidad_flash : hint_range(0.0, 1.0) = 0.0;

void fragment() {
	vec4 original = texture(TEXTURE, UV);
	original.rgb = mix(original.rgb, vec3(1.0), intensidad_flash);
	COLOR = original;
}
