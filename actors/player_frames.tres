[gd_resource type="SpriteFrames" load_steps=37 format=3 uid="uid://arenaplayerframes01"]

; === SpriteFrames del caballero (knight2) =================================
; Cada hoja (_Idle, _Run, ...) es 1200x80 (o 480x80 / 120x80). El personaje
; vive en la FILA DE ABAJO: por eso cada frame es una región de 120x40 con
; y=40. Cada AtlasTexture recorta un frame de su hoja.
;
; OJO con los flags "loop": idle/run hacen loop (no emiten animation_finished);
; attack/hurt/death NO hacen loop (emiten animation_finished UNA vez al
; terminar). Esa diferencia es el corazón de la FSM del jugador.
; ==========================================================================

