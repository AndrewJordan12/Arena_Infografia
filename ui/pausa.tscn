[gd_scene load_steps=2 format=3 uid="uid://arenapausa01"]

[ext_resource type="Script" path="res://ui/pausa.gd" id="1"]

[node name="Pausa" type="CanvasLayer" process_mode="3"]
script = ExtResource("1")

[node name="Centro" type="CenterContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Panel" type="PanelContainer" parent="Centro"]
layout_mode = 2

[node name="Caja" type="VBoxContainer" parent="Centro/Panel"]
layout_mode = 2
theme_override_constants/separation = 14

[node name="Titulo" type="Label" parent="Centro/Panel/Caja"]
